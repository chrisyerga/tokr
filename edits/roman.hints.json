  "fixedOverlays": [
    {
      "id": "title-card",
      "generator": "TitleCardOverlay",
      "mode": "overlay",
      "start": 0,
      "end": 4.5,
      "params": {}
    },
    {
      "id": "nancy-intro",
      "generator": "NancyIntro",
      "mode": "overlay",
      "start": 5.5,
      "end": 11.0,
      "params": {}
    },
    {
      "id": "exoplanet-trio",
      "generator": "ExoplanetTrio",
      "mode": "overlay",
      "start": 12.0,
      "end": 17.0,
      "params": {}
    },
    {
      "id": "earth-escape",
      "generator": "EarthEscape",
      "mode": "overlay",
      "start": 21.5,
      "end": 29.0,
      "params": {}
    }
  ],
  "overlayHints": [
    {
      "id": "goldilocks",
      "generator": "Goldilocks",
      "mode": "overlay",
      "match": ["goldilocks", "goldilocks zone"]
    },
    {
      "id": "spy-nro",
      "generator": "SpySatellite",
      "mode": "fullscreen",
      "match": ["National Reconnaissance", "couch cushions"]
    },
    {
      "id": "transit",
      "generator": "TransitMethod",
      "mode": "fullscreen",
      "match": ["measure the brightness", "dip in brightness"]
    },
    {
      "id": "spectroscopy",
      "generator": "Spectroscopy",
      "mode": "fullscreen",
      "match": ["spectroscopy"]
    }
  ],
  "fps": 30,
  "width": 1080,
  "height": 1920,
  "subtitleStyle": {
    "fontFamily": "Montserrat",
    "fontWeight": 800,
    "fontSize": 64,
    "color": "#FFFFFF",
    "highlightColor": "#FFD400",
    "outlineColor": "#000000",
    "outlineWidth": 8,
    "bottomOffset": 280,
    "maxWordsPerChunk": 4
  },
  "audio": {
    "loudnorm": true,
    "targetLufs": -16,
    "crossfadeMs": 40
  }
}
